<%- include('../partials/layout-start', { title: facility ? facility.name + ' の編集' : '設備登録', current: 'facilities' }) %>

<a href="/facilities" class="text-muted" style="font-size:13px">← 設備管理に戻る</a>

<div class="card mt-4" style="max-width:480px">
  <div class="card-header"><%= facility ? '設備情報の編集' : '新規設備登録' %></div>
  <div class="card-body">

    <% if(error) { %>
    <div style="background:#fee2e2;border:1px solid #fca5a5;color:#b91c1c;padding:12px 16px;border-radius:8px;margin-bottom:16px">⚠️ <%= error %></div>
    <% } %>

    <form method="post" action="<%= facility ? '/facilities/' + facility.id + '/edit' : '/facilities' %>">

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">設備名 <span style="color:#dc2626">*</span></label>
        <input type="text" name="name" value="<%= facility ? facility.name : '' %>" required
               style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px"
               placeholder="例: 普通車-001、第1教室、シミュレーターA">
      </div>

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">カテゴリ <span style="color:#dc2626">*</span></label>
        <select name="category" id="category" onchange="toggleLicenseType()"
                style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
          <% ['車両','教室','シミュレーター','その他'].forEach(c => { %>
            <option value="<%= c %>" <%= facility && facility.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>

      <div id="license-type-section" style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">対象車種</label>
        <select name="license_type" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
          <option value="">なし（教室等）</option>
          <% ['普通車','二輪','大型'].forEach(t => { %>
            <option value="<%= t %>" <%= facility && facility.license_type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">定員（同時利用人数）</label>
        <input type="number" name="capacity" value="<%= facility ? facility.capacity : 1 %>" min="1"
               style="width:100px;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
        <span class="text-muted" style="margin-left:8px">名</span>
      </div>

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">ステータス</label>
        <select name="status" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
          <% ['使用可','点検中','使用不可','廃止'].forEach(s => { %>
            <option value="<%= s %>" <%= facility && facility.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>

      <div style="margin-bottom:20px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">備考</label>
        <textarea name="note" rows="2"
                  style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;resize:vertical"><%= facility ? facility.note || '' : '' %></textarea>
      </div>

      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary"><%= facility ? '更新する' : '登録する' %></button>
        <a href="/facilities" class="btn btn-secondary">キャンセル</a>
      </div>

    </form>
  </div>
</div>

<script>
function toggleLicenseType() {
  const cat = document.getElementById('category').value;
  document.getElementById('license-type-section').style.display = (cat === '教室') ? 'none' : '';
}
toggleLicenseType();
</script>

<%- include('../partials/layout-end') %>
