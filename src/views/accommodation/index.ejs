<%- include('../partials/layout-start', { title: '宿泊管理', current: 'accommodation' }) %>

<div class="card mb-4">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    施設一覧
    <div style="display:flex;gap:8px">
      <a href="/accommodation/occupancy" class="btn btn-secondary" style="font-size:12px;padding:5px 14px">📅 日別在室状況</a>
      <a href="/accommodation/assign" class="btn btn-secondary" style="font-size:12px;padding:5px 14px">＋ 部屋を割り当てる</a>
      <a href="/accommodation/new" class="btn btn-primary" style="font-size:12px;padding:5px 14px">＋ 施設登録</a>
    </div>
  </div>
  <div class="card-body">
    <table>
      <tr><th>施設名</th><th>部屋数</th><th>収容定員</th><th>在室中</th><th>空き</th><th>ステータス</th><th>備考</th><th></th></tr>
      <% for(const a of accommodations) { %>
      <% const occupied = occupancyMap[a.id] || 0; const available = a.total_capacity - occupied; %>
      <tr>
        <td><a href="/accommodation/<%= a.id %>"><%= a.name %></a></td>
        <td><%= a.total_rooms %> 室</td>
        <td><%= a.total_capacity %> 名</td>
        <td><%= occupied %> 名</td>
        <td>
          <span class="badge <%= available <= 0 ? 'badge-red' : available <= 2 ? 'badge-orange' : 'badge-green' %>">
            <%= available %> 名
          </span>
        </td>
        <td><span class="badge <%= a.status === '使用可' ? 'badge-green' : 'badge-gray' %>"><%= a.status %></span></td>
        <td class="text-muted"><%= a.note || '—' %></td>
        <td>
          <a href="/accommodation/<%= a.id %>" class="btn btn-secondary" style="font-size:12px;padding:4px 10px">詳細</a>
          <a href="/accommodation/<%= a.id %>/edit" class="btn btn-secondary" style="font-size:12px;padding:4px 10px;margin-left:4px">編集</a>
        </td>
      </tr>
      <% } %>
    </table>
  </div>
</div>

<div class="card">
  <div class="card-header">在室者一覧（在校生）</div>
  <div class="card-body">
    <table>
      <tr><th>施設</th><th>部屋</th><th>生徒</th><th>車種</th><th>入校日</th><th>卒業予定</th></tr>
      <% for(const r of residents) { %>
      <tr>
        <td><%= r.accommodation_name %></td>
        <td><%= r.room_name %></td>
        <td><a href="/students/<%= r.id %>"><%= r.name %></a></td>
        <td><span class="badge badge-blue"><%= r.license_type %></span></td>
        <td><%= r.enrollment_date %></td>
        <td><%= r.expected_graduation || '—' %></td>
      </tr>
      <% } %>
    </table>
  </div>
</div>

<%- include('../partials/layout-end') %>
