<%- include('../partials/layout-start', { title: '日別在室状況', current: 'accommodation' }) %>

<%
  // 背景色の明度から文字色を導出（赤帯→白文字／淡色→黒文字）
  function textOn(hex) {
    if (!hex) return '#1e2a3a';
    const c = hex.replace('#', '');
    const r = parseInt(c.substr(0,2),16), g = parseInt(c.substr(2,2),16), b = parseInt(c.substr(4,2),16);
    return (0.299*r + 0.587*g + 0.114*b) < 145 ? '#ffffff' : '#1e2a3a';
  }
  // 祝日（※暫定・2026年主要分。将来は祝日マスタ化）
  const HOLIDAYS = new Set([
    '2026-01-01','2026-01-12','2026-02-11','2026-02-23','2026-03-20','2026-04-29',
    '2026-05-03','2026-05-04','2026-05-05','2026-05-06','2026-07-20','2026-08-11',
    '2026-09-21','2026-09-22','2026-09-23','2026-10-12','2026-11-03','2026-11-23'
  ]);
  const DOW = ['日','月','火','水','木','金','土'];
%>

<div style="background:#fffbeb;border:1px solid #fde68a;color:#854d0e;padding:10px 16px;border-radius:8px;margin:16px 0;font-size:13px">
  ※ 利用形態の色・部屋の定員・滞在期間・祝日は<strong>暫定</strong>です（要現地確認）。Excelの在室表をWebで再現・拡張した叩き台です。
</div>

<div class="card mb-4">
  <div class="card-body" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    <a href="/accommodation" class="text-muted" style="font-size:13px">← 宿泊管理</a>
    <a href="/accommodation/assign" class="btn btn-secondary" style="font-size:12px">＋ 部屋を割り当てる</a>
    <div style="display:flex;gap:8px;align-items:center;margin-left:auto">
      <a href="/accommodation/occupancy?from=<%= prevFrom %>&days=<%= days %>" class="btn btn-secondary">◀ 前<%= days %>日</a>
      <span style="font-size:13px;color:#555"><%= from %> 〜（<%= days %>日）</span>
      <a href="/accommodation/occupancy?from=<%= nextFrom %>&days=<%= days %>" class="btn btn-secondary">次<%= days %>日 ▶</a>
    </div>
    <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;width:100%;border-top:1px solid #f0f2f5;padding-top:10px">
      <span class="text-muted" style="font-size:12px">利用形態：</span>
      <% for(const u of usageTypes) { %>
        <span style="display:flex;align-items:center;gap:5px;font-size:12px">
          <span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:<%= u.color_code %>;border:1px solid #ccc"></span><%= u.display_name %>
        </span>
      <% } %>
      <span style="display:flex;align-items:center;gap:5px;font-size:12px;color:#9ca3af">｜セルの数字＝空き人数</span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body" style="overflow-x:auto;padding:0">
    <table style="border-collapse:separate;border-spacing:0;table-layout:fixed">
      <thead>
        <tr>
          <th style="position:sticky;left:0;background:#f0f4f8;z-index:3;min-width:150px;border:1px solid #d7dce3;padding:8px 10px;font-size:12px;text-align:left">施設 / 部屋</th>
          <% for(const dt of dates) {
               const d = new Date(dt); const dow = d.getDay();
               const isHol = HOLIDAYS.has(dt);
               const mm = String(d.getMonth()+1).padStart(2,'0'); const dd = String(d.getDate()).padStart(2,'0');
               const headBg = dt===today ? '#fff3cd' : (isHol||dow===0) ? '#fdecec' : dow===6 ? '#eaf2fd' : '#f8fafc';
               const headFg = (isHol||dow===0) ? '#dc2626' : dow===6 ? '#2563eb' : '#555';
          %>
          <% const todayBorder = dt===today ? 'border-left:2px solid #f59e0b;border-right:2px solid #f59e0b;' : 'border:1px solid #d7dce3;'; %>
          <th style="min-width:32px;width:32px;<%= todayBorder %>border-top:1px solid #d7dce3;padding:3px 0;font-size:11px;background:<%= headBg %>;color:<%= headFg %>;font-weight:600">
            <% if(dt===today){ %><div style="font-size:8px;color:#b45309;font-weight:700">今日</div><% } %>
            <%= mm %>/<%= dd %><br><span style="font-size:10px"><%= DOW[dow] %></span>
          </th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% let lastAccom = ''; %>
        <% for(const r of rooms) { %>
          <% if(r.accommodation_name !== lastAccom) { lastAccom = r.accommodation_name; %>
          <tr><td colspan="<%= dates.length + 1 %>" style="position:sticky;left:0;background:#e3e9f2;font-size:11px;font-weight:700;color:#3b4a5e;padding:5px 10px;border:1px solid #d7dce3">🏠 <%= r.accommodation_name %></td></tr>
          <% } %>
          <tr>
            <% const st = roomStatus[r.id] || { kind:'free', label:'' };
               const stColor = st.kind==='single' ? '#dc2626' : st.kind==='full' ? '#dc2626' : st.kind==='over' ? '#b45309' : '#16a34a';
               const stBg = st.kind==='single' ? '#fde2e2' : st.kind==='full' ? '#fde2e2' : st.kind==='over' ? '#fef3c7' : '#fef9c3';
            %>
            <td style="position:sticky;left:0;z-index:2;background:<%= stBg %>;border:1px solid #d7dce3;padding:6px 10px;font-size:13px;font-weight:700;color:#1e2a3a;white-space:nowrap">
              <%= r.room_name %>
              <span style="font-weight:400;color:#9a8c2a;font-size:10px">定員<%= r.capacity %><% if(r.over_capacity) { %>+<%= r.over_capacity %><% } %></span>
              <div style="font-size:10px;font-weight:700;color:<%= stColor %>;margin-top:2px">今日：<%= st.label %></div>
            </td>
            <% for(const dt of dates) {
                 const cell = byRoom[r.id] && byRoom[r.id][dt];
                 const todayB = dt===today ? 'border-left:2px solid #f59e0b;border-right:2px solid #f59e0b;' : '';
            %>
              <% if(cell) {
                   const fg = textOn(cell.color);
                   const br = cell.isStart && cell.isEnd ? '7px' : cell.isStart ? '7px 0 0 7px' : cell.isEnd ? '0 7px 7px 0' : '0';
                   // シングル(占有)は帯を行いっぱいに塗ってガッツリ塞ぐ＝Excelの行結合に近い占有感
                   const pad = cell.isExclusive ? '0' : '3px';
              %>
                <td title="<%= cell.name %>（<%= cell.usage %>）<%= cell.isExclusive?'｜部屋占有':'' %>" style="border-top:1px solid #d7dce3;border-bottom:1px solid #d7dce3;<%= todayB %>padding:0;height:34px;position:relative;background:#fff">
                  <div style="position:absolute;top:<%= pad %>;bottom:<%= pad %>;left:<%= cell.isStart?'3px':'0' %>;right:<%= cell.isEnd?'3px':'0' %>;background:<%= cell.color %>;border-radius:<%= br %>;display:flex;align-items:center;justify-content:center;overflow:visible;white-space:nowrap">
                    <% if(cell.showName) { %><span style="font-size:12px;font-weight:700;color:<%= fg %>;padding:0 4px"><% if(cell.isExclusive){ %>🔒 <% } %><%= cell.name %><% if(cell.isExclusive){ %>（シングル）<% } %></span><% } %>
                  </div>
                </td>
              <% } else {
                   const v = (vacancy[r.id] && vacancy[r.id][dt]);
                   const d = new Date(dt); const isWk = d.getDay()===0 || d.getDay()===6 || HOLIDAYS.has(dt);
              %>
                <td style="border:1px solid #eef1f5;<%= todayB %>padding:0;height:34px;text-align:center;font-size:10px;color:<%= v>0?'#cbd5e1':'#f87171' %>;background:<%= dt===today?'#fffdf5':isWk?'#fcfcfd':'#fff' %>"><%= v %></td>
              <% } %>
            <% } %>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<p class="text-muted" style="font-size:12px;margin-top:10px">
  色帯＝滞在中（中央に氏名）。空きセルの数字＝その日の空き人数。在室状況・空き人数はDBに保存せず、割当イベントと定員から毎回計算しています。
</p>

<%- include('../partials/layout-end') %>
