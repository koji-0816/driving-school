<%- include('../partials/layout-start', { title: '日別在室状況', current: 'accommodation' }) %>

<div style="background:#fffbeb;border:1px solid #fde68a;color:#854d0e;padding:10px 16px;border-radius:8px;margin:16px 0;font-size:13px">
  ※ 利用形態の色・部屋の定員・滞在期間は<strong>暫定</strong>です（要現地確認）。Excelの在室表をWebで再現した叩き台です。
</div>

<!-- ヘッダー：期間ナビ＋凡例 -->
<div class="card mb-4">
  <div class="card-body" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
    <a href="/accommodation" class="text-muted" style="font-size:13px">← 宿泊管理</a>
    <div style="display:flex;gap:8px;align-items:center;margin-left:auto">
      <a href="/accommodation/occupancy?from=<%= prevFrom %>&days=<%= days %>" class="btn btn-secondary">◀ 前<%= days %>日</a>
      <span style="font-size:13px;color:#555"><%= from %> 〜（<%= days %>日）</span>
      <a href="/accommodation/occupancy?from=<%= nextFrom %>&days=<%= days %>" class="btn btn-secondary">次<%= days %>日 ▶</a>
    </div>
    <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;width:100%;border-top:1px solid #f0f2f5;padding-top:10px">
      <span class="text-muted" style="font-size:12px">利用形態：</span>
      <% for(const u of usageTypes) { %>
        <span style="display:flex;align-items:center;gap:5px;font-size:12px">
          <span style="display:inline-block;width:14px;height:14px;border-radius:3px;background:<%= u.color_code %>;border:1px solid #ccc"></span><%= u.display_name %>
        </span>
      <% } %>
      <span style="display:flex;align-items:center;gap:5px;font-size:12px">
        <span style="display:inline-block;width:14px;height:14px;border-radius:3px;background:#f9fafb;border:1px solid #e5e7eb"></span>数字＝空き人数
      </span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body" style="overflow-x:auto;padding:8px">
    <table style="border-collapse:collapse;table-layout:fixed">
      <thead>
        <tr>
          <th style="position:sticky;left:0;background:#f0f4f8;z-index:2;min-width:140px;border:1px solid #e0e4ea;padding:6px 8px;font-size:12px;text-align:left">施設 / 部屋</th>
          <%
            const DOW = ['日','月','火','水','木','金','土'];
          %>
          <% for(const dt of dates) {
               const d = new Date(dt); const dow = d.getDay();
               const mm = String(d.getMonth()+1).padStart(2,'0'); const dd = String(d.getDate()).padStart(2,'0');
          %>
          <th style="min-width:34px;width:34px;border:1px solid #e0e4ea;padding:3px 0;font-size:11px;background:<%= dt===today?'#fffbeb':'#f8fafc' %>;color:<%= dow===0?'#dc2626':dow===6?'#2563eb':'#555' %>">
            <%= mm %>/<%= dd %><br><span style="font-size:10px"><%= DOW[dow] %></span>
          </th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% let lastAccom = ''; %>
        <% for(const r of rooms) { %>
          <% if(r.accommodation_name !== lastAccom) { lastAccom = r.accommodation_name; %>
          <tr><td colspan="<%= dates.length + 1 %>" style="background:#eef2f7;font-size:11px;font-weight:700;color:#555;padding:4px 8px;border:1px solid #e0e4ea">🏠 <%= r.accommodation_name %></td></tr>
          <% } %>
          <tr>
            <td style="position:sticky;left:0;background:#fff;z-index:1;border:1px solid #e0e4ea;padding:5px 8px;font-size:12px;white-space:nowrap">
              <%= r.room_name %> <span class="text-muted" style="font-size:10px">定員<%= r.capacity %><% if(r.over_capacity) { %>+<%= r.over_capacity %><% } %></span>
            </td>
            <% for(const dt of dates) {
                 const cell = byRoom[r.id] && byRoom[r.id][dt];
            %>
              <% if(cell) { %>
                <td title="<%= cell.name %>（<%= cell.usage %>）" style="border:1px solid #e0e4ea;padding:0;background:<%= cell.color %>;height:30px;overflow:hidden;font-size:10px;color:#1e2a3a;text-align:center;white-space:nowrap">
                  <% if(cell.isStart) { %><span style="padding:0 3px;font-weight:600"><%= cell.name %></span><% } %>
                </td>
              <% } else { %>
                <% const v = (vacancy[r.id] && vacancy[r.id][dt]); %>
                <td style="border:1px solid #e0e4ea;padding:0;height:30px;text-align:center;font-size:10px;color:<%= v>0?'#9ca3af':'#dc2626' %>;background:<%= dt===today?'#fffdf5':'#fff' %>"><%= v %></td>
              <% } %>
            <% } %>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<p class="text-muted" style="font-size:12px;margin-top:10px">
  色帯＝滞在中（左端に氏名）。空きセルの数字＝その日の空き人数。在室状況・空き人数はDBに保存せず、割当イベントと定員から毎回計算しています。
</p>

<%- include('../partials/layout-end') %>
