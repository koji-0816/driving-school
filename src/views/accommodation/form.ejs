<%- include('../partials/layout-start', { title: accommodation ? accommodation.name + ' の編集' : '施設登録', current: 'accommodation' }) %>

<a href="/accommodation" class="text-muted" style="font-size:13px">← 宿泊管理に戻る</a>

<div class="card mt-4" style="max-width:480px">
  <div class="card-header"><%= accommodation ? '施設情報の編集' : '宿泊施設の新規登録' %></div>
  <div class="card-body">

    <% if(error) { %>
    <div style="background:#fee2e2;border:1px solid #fca5a5;color:#b91c1c;padding:12px 16px;border-radius:8px;margin-bottom:16px">⚠️ <%= error %></div>
    <% } %>

    <form method="post" action="<%= accommodation ? '/accommodation/' + accommodation.id + '/edit' : '/accommodation' %>">

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">施設名 <span style="color:#dc2626">*</span></label>
        <input type="text" name="name" value="<%= accommodation ? accommodation.name : '' %>" required
               style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px"
               placeholder="例: 第1寮">
      </div>

      <div style="margin-bottom:14px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">ステータス</label>
        <select name="status" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
          <% ['使用可','使用不可'].forEach(s => { %>
            <option value="<%= s %>" <%= accommodation && accommodation.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>

      <div style="margin-bottom:20px">
        <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">備考</label>
        <textarea name="note" rows="3"
                  style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;resize:vertical"><%= accommodation ? accommodation.note || '' : '' %></textarea>
      </div>

      <% if(accommodation) { %>
      <p class="text-muted" style="font-size:12px;margin-bottom:16px">
        部屋の登録・編集は <a href="/accommodation/<%= accommodation.id %>">施設詳細ページ</a> から行えます。
      </p>
      <% } %>

      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary"><%= accommodation ? '更新する' : '登録する' %></button>
        <a href="/accommodation" class="btn btn-secondary">キャンセル</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
