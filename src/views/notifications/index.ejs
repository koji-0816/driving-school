<%- include('../partials/layout-start', { title: '通知', current: 'notifications' }) %>

<a href="/students/<%= student.id %>" class="text-muted" style="font-size:13px">← マイページに戻る</a>

<div class="card mt-4">
  <div class="card-header">通知一覧</div>
  <div class="card-body">
    <% if(notifications.length === 0) { %>
      <p class="text-muted">通知はありません</p>
    <% } else { %>
    <% for(const n of notifications) { %>
    <div style="padding:12px 0;border-bottom:1px solid #f0f2f5;display:flex;gap:12px;align-items:flex-start">
      <div style="width:8px;height:8px;border-radius:50%;background:<%= n.is_read ? '#d1d5db' : '#2563eb' %>;margin-top:6px;flex-shrink:0"></div>
      <div style="flex:1">
        <div style="font-weight:<%= n.is_read ? '400' : '600' %>;font-size:14px;color:<%= n.is_read ? '#9ca3af' : '#1e2a3a' %>"><%= n.title %></div>
        <div style="font-size:13px;color:#6b7280;margin-top:2px"><%= n.message %></div>
        <div style="font-size:11px;color:#9ca3af;margin-top:4px"><%= n.created_at %></div>
      </div>
      <span class="badge <%= n.type.startsWith('deadline') ? 'badge-orange' : n.type === 'waitlist_promoted' ? 'badge-green' : 'badge-blue' %>">
        <%= n.type.startsWith('deadline') ? '期限' : n.type === 'waitlist_promoted' ? '繰り上がり' : 'お知らせ' %>
      </span>
    </div>
    <% } %>
    <% } %>
  </div>
</div>

<%- include('../partials/layout-end') %>
