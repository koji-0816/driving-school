<%- include('../partials/layout-start', { title: student.name, current: 'students' }) %>

<div style="display:flex;justify-content:space-between;align-items:center">
  <a href="/students" class="text-muted" style="font-size:13px">← 生徒一覧</a>
  <a href="/students/<%= student.id %>/edit" class="btn btn-secondary">編集</a>
</div>

<div class="grid-2 mt-4">

  <div class="card">
    <div class="card-header">基本情報</div>
    <div class="card-body">
      <table>
        <tr><th style="width:120px">氏名</th><td><%= student.name %></td></tr>
        <tr><th>フリガナ</th><td><%= student.kana %></td></tr>
        <tr><th>取得車種</th><td>
          <span class="badge <%= student.license_type === '普通車' ? 'badge-blue' : student.license_type === '二輪' ? 'badge-orange' : 'badge-purple' %>">
            <%= student.license_type %>
          </span>
        </td></tr>
        <tr><th>電話</th><td><%= student.phone || '—' %></td></tr>
        <tr><th>メール</th><td><%= student.email || '—' %></td></tr>
        <tr><th>入校日</th><td><%= student.enrollment_date %></td></tr>
        <tr><th>卒業予定</th><td><%= student.expected_graduation || '—' %></td></tr>
        <tr><th>ステータス</th><td>
          <span class="badge <%= student.status === '在校' ? 'badge-green' : student.status === '卒業' ? 'badge-blue' : 'badge-gray' %>">
            <%= student.status %>
          </span>
        </td></tr>
        <tr><th>区分</th><td>
          <span class="badge <%= student.student_type === '合宿' ? 'badge-blue' : 'badge-green' %>"><%= student.student_type %></span>
        </td></tr>
        <tr><th>宿泊室</th><td><%= student.room_name ? `${student.accommodation_name} ${student.room_name}` : student.student_type === '通学' ? '通学（宿泊なし）' : '—' %></td></tr>
        <% if(student.student_type === '合宿') { %>
        <tr><th>卒業予定</th><td><%= student.expected_graduation || '—' %></td></tr>
        <% } %>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header">教習進捗</div>
    <div class="card-body">
      <div style="margin-bottom:16px">
        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
          <span>第一段階</span>
          <span class="text-muted"><%= stageMap['第一段階'] || 0 %> 時限完了</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" style="width:<%= Math.min(100, ((stageMap['第一段階'] || 0) / 15) * 100) %>%"></div>
        </div>
        <div class="text-muted" style="margin-top:2px">目安: 15時限</div>
      </div>
      <div>
        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
          <span>第二段階</span>
          <span class="text-muted"><%= stageMap['第二段階'] || 0 %> 時限完了</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill green" style="width:<%= Math.min(100, ((stageMap['第二段階'] || 0) / 19) * 100) %>%"></div>
        </div>
        <div class="text-muted" style="margin-top:2px">目安: 19時限</div>
      </div>
    </div>
  </div>

</div>

<% if(student.student_type === '通学') { %>
<div class="card mb-4">
  <div class="card-header">期限管理（通学生）</div>
  <div class="card-body">
    <%
      function deadlineRow(label, startLabel, startDate, deadline, level) {
        if (!startDate) return '';
        const cls = level === 'expired' ? '#fee2e2' : level === 'warn' ? '#fff7ed' : '#f0fdf4';
        const mark = level === 'expired' ? '⚠️ 期限切れ' : level === 'warn' ? '⚠️ 残り30日以内' : '✓ 有効';
        return `<tr style="background:${cls}">
          <td style="padding:10px 12px;font-weight:600">${label}</td>
          <td style="padding:10px 12px">${startLabel}：${startDate}</td>
          <td style="padding:10px 12px;font-weight:600">${deadline}</td>
          <td style="padding:10px 12px">${mark}</td>
        </tr>`;
      }
    %>
    <table>
      <tr><th>種別</th><th>起算日</th><th>期限日</th><th>状態</th></tr>
      <%- deadlineRow('教習期限（9ヶ月）', '最初の教習日', student.lesson_start_date, lessonDeadline, lessonLevel) %>
      <%- deadlineRow('仮免期限（6ヶ月）', '仮免取得日', student.provisional_license_date, provLicDeadline, provLicLevel) %>
      <%- deadlineRow('卒検期限（3ヶ月）', '第二段階修了日', student.stage2_complete_date, stage2Deadline, stage2Level) %>
      <% if(!student.lesson_start_date && !student.provisional_license_date && !student.stage2_complete_date) { %>
      <tr><td colspan="4" class="text-muted" style="padding:12px">起算日が未登録のため計算できません</td></tr>
      <% } %>
    </table>
  </div>
</div>
<% } %>

<div class="card">
  <div class="card-header">教習履歴（直近20件）</div>
  <div class="card-body">
    <% if(lessons.length === 0) { %>
      <p class="text-muted">教習記録がありません</p>
    <% } else { %>
    <table>
      <tr><th>日付</th><th>時限</th><th>種別</th><th>段階</th><th>教官</th><th>車両</th><th>ステータス</th></tr>
      <% for(const l of lessons) { %>
      <tr>
        <td><%= l.lesson_date %></td>
        <td><%= l.start_time %>〜<%= l.end_time %></td>
        <td><%= l.lesson_type %></td>
        <td><span class="badge badge-gray"><%= l.stage %></span></td>
        <td><%= l.instructor_name %></td>
        <td><%= l.vehicle_no || '—' %></td>
        <td>
          <span class="badge <%= l.status === '完了' ? 'badge-green' : l.status === '欠席' ? 'badge-red' : l.status === 'キャンセル' ? 'badge-gray' : 'badge-blue' %>">
            <%= l.status %>
          </span>
        </td>
      </tr>
      <% } %>
    </table>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-header">検定履歴</div>
  <div class="card-body">
    <% if(exams.length === 0) { %>
      <p class="text-muted">検定記録がありません</p>
    <% } else { %>
    <table>
      <tr><th>日付</th><th>種別</th><th>結果</th><th>点数</th><th>検定員</th></tr>
      <% for(const e of exams) { %>
      <tr>
        <td><%= e.exam_date %></td>
        <td><span class="badge badge-purple"><%= e.exam_type %></span></td>
        <td>
          <span class="badge <%= e.result === '合格' ? 'badge-green' : e.result === '不合格' ? 'badge-red' : 'badge-gray' %>">
            <%= e.result %>
          </span>
        </td>
        <td><%= e.score !== null ? e.score + '点' : '—' %></td>
        <td><%= e.examiner_name %></td>
      </tr>
      <% } %>
    </table>
    <% } %>
  </div>
</div>


<%# 教習コース・計画・免除（閲覧。Step3 plan方式の価値体験） %>
<div class="card mb-4">
  <div class="card-header">教習コース・計画</div>
  <div class="card-body">
    <% if(isPlanBased) { %>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px">
        <span class="badge badge-blue">コース確定</span>
        <strong style="font-size:15px"><%= planCourse.name %></strong>
        <span class="text-muted" style="font-size:12px"><%= planCourse.family %></span>
      </div>
      <div class="text-muted" style="font-size:12px">
        入校時に展開された教習計画（必要教習 <%= plan.length %> 項目）。展開元コース版ID: <%= planCourse.source_course_id %>
      </div>

      <% if(exemptions && exemptions.length > 0) { %>
      <div style="margin-top:16px;padding:14px 16px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px">
        <div style="font-size:13px;font-weight:700;color:#0369a1;margin-bottom:8px">
          免除済み科目（<%= exemptions.length %> 件）
        </div>
        <div style="font-size:12px;color:#0369a1;margin-bottom:10px">
          理由：<%= exemptions[0].reason_name %>
          <span class="text-muted">— これらは受講せず、前提条件は満たした扱いになります</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          <% for(const ex of exemptions) { %>
            <span class="badge badge-gray" title="<%= ex.reason_name %>"><%= ex.code %> <%= ex.name %></span>
          <% } %>
        </div>
        <div style="margin-top:10px;font-size:11px;color:#b45309;background:#fffbeb;border:1px solid #fde68a;border-radius:6px;padding:8px 10px">
          ⚠ 免除内容は暫定です（要法令・現場確認）。実際の免除科目・範囲は現地運用に合わせて確定します。
        </div>
      </div>
      <% } %>
    <% } else { %>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="badge badge-gray">従来方式</span>
        <span class="text-muted" style="font-size:13px">
          取得希望免許（AT/MT）未設定のため、従来方式（全科目）で表示中です。
          編集画面で取得希望免許を設定すると、入校時にコース別の教習計画が展開されます。
        </span>
      </div>
    <% } %>
  </div>
</div>

<% if(progress && progress.length > 0) { %>
<%
  // 表示用に段階×種別でグループ化
  const groups = [
    { stage: 1, type: '学科', label: '第一段階 — 学科' },
    { stage: 1, type: '技能', label: '第一段階 — 技能' },
    { stage: 1, type: '検定', label: '第一段階 — 検定' },
    { stage: 2, type: '学科', label: '第二段階 — 学科' },
    { stage: 2, type: '技能', label: '第二段階 — 技能' },
    { stage: 2, type: '検定', label: '第二段階 — 検定' },
  ];

  const today2 = new Date().toISOString().split('T')[0];

  function statusBadge(s) {
    if (s === 'completed') return '<span class="badge badge-green">受講済</span>';
    if (s === 'available') return '<span class="badge badge-blue">受講可</span>';
    return '<span class="badge badge-gray">受講不可</span>';
  }
%>

<div class="card mb-4">
  <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
    カリキュラム進捗
    <% if(currentRole === 'admin' || currentRole === 'instructor') { %>
    <button class="btn btn-secondary" style="font-size:12px" onclick="document.getElementById('record-panel').classList.toggle('hidden')">
      + 受講記録を登録
    </button>
    <% } %>
  </div>

  <%# 受講記録フォーム（admin/instructor のみ） %>
  <% if(currentRole === 'admin' || currentRole === 'instructor') { %>
  <div id="record-panel" class="hidden" style="padding:16px 20px;border-bottom:1px solid #f0f2f5;background:#f8fafc">
    <form method="post" action="/students/<%= student.id %>/record-lesson" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
      <div>
        <label style="font-size:12px;color:#555;display:block;margin-bottom:4px">科目</label>
        <select name="lesson_master_id" required style="padding:7px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;min-width:220px">
          <option value="">— 科目を選択 —</option>
          <% for(const p of availableForRecord) { %>
          <option value="<%= p.lesson.id %>">
            [<%= p.lesson.stage === 1 ? '第一' : '第二' %>段階 / <%= p.lesson.lesson_type %>]
            <%= p.lesson.code %> <%= p.lesson.name %>
            <% if(p.status === 'completed') { %>(完了済み)<% } %>
          </option>
          <% } %>
        </select>
      </div>
      <div>
        <label style="font-size:12px;color:#555;display:block;margin-bottom:4px">受講日</label>
        <input type="date" name="lesson_date" value="<%= today2 %>" required
          style="padding:7px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px">
      </div>
      <div>
        <label style="font-size:12px;color:#555;display:block;margin-bottom:4px">担当教官</label>
        <select name="instructor_id" style="padding:7px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px">
          <option value="">— 選択 —</option>
          <% for(const inst of instructors) { %>
          <option value="<%= inst.id %>" <%= currentRole === 'instructor' && currentUserId == inst.id ? 'selected' : '' %>>
            <%= inst.name %>
          </option>
          <% } %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary" style="height:34px">登録</button>
    </form>
  </div>
  <% } %>

  <div class="card-body" style="padding:12px 20px">
    <% for(const g of groups) {
      const items = progress.filter(p => p.lesson.stage === g.stage && p.lesson.lesson_type === g.type);
      if(items.length === 0) continue;
      const doneCount  = items.filter(p => p.status === 'completed').length;
    %>
    <div style="margin-bottom:20px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <span style="font-size:12px;font-weight:700;color:#6b7280;letter-spacing:0.05em"><%= g.label %></span>
        <span style="font-size:11px;color:#9ca3af"><%= doneCount %> / <%= items.length %> 完了</span>
      </div>
      <table style="width:100%;border-collapse:collapse">
        <% for(const p of items) { %>
        <tr style="border-bottom:1px solid #f3f4f6">
          <td style="padding:7px 0;width:80px"><%- statusBadge(p.status) %></td>
          <td style="padding:7px 4px;font-size:12px;color:#9ca3af;white-space:nowrap"><%= p.lesson.code %></td>
          <td style="padding:7px 8px;font-size:13px;color:<%= p.status === 'locked' ? '#9ca3af' : '#1e2a3a' %>">
            <%= p.lesson.name %>
            <% if(p.lesson.required_count > 1) { %>
            <span style="font-size:11px;color:#9ca3af">（<%= p.completedCount %>/<%= p.lesson.required_count %>時限）</span>
            <% } %>
          </td>
          <td style="padding:7px 0;font-size:11px;color:#ef4444">
            <% if(p.status === 'locked') { %>
            <% for(const reason of p.blockedBy) { %><div>🔒 <%= reason %></div><% } %>
            <% } %>
          </td>
        </tr>
        <% } %>
      </table>
    </div>
    <% } %>
  </div>
</div>
<% } %>

<style>
.hidden { display: none !important; }
</style>

<%- include('../partials/layout-end') %>
