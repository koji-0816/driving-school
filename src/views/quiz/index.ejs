<%- include('../partials/layout-start', { title: '学科試験対策', current: 'quiz' }) %>

<a href="/students/<%= student.id %>" class="text-muted" style="font-size:13px">← マイページに戻る</a>

<div class="grid-2 mt-4 mb-4">
  <% const categories = ['法規','標識','安全','技術']; %>
  <% for(const cat of categories) {
    const s = stats.find(s => s.category === cat);
    const pct = s ? Math.round(s.correct / s.total * 100) : null;
  %>
  <div class="card" style="cursor:pointer" onclick="location.href='/quiz/<%= student.id %>/start?category=<%= cat %>'">
    <div class="card-body" style="text-align:center;padding:20px">
      <div style="font-size:14px;font-weight:600;color:#1e2a3a;margin-bottom:8px"><%= cat %></div>
      <% if(pct !== null) { %>
        <div style="font-size:28px;font-weight:700;color:<%= pct >= 80 ? '#16a34a' : pct >= 60 ? '#d97706' : '#dc2626' %>"><%= pct %>%</div>
        <div class="text-muted" style="font-size:11px;margin-top:2px"><%= s.correct %>/<%= s.total %>問正解</div>
      <% } else { %>
        <div style="font-size:14px;color:#9ca3af">未受験</div>
      <% } %>
      <div class="btn btn-secondary" style="margin-top:12px;font-size:12px">練習する</div>
    </div>
  </div>
  <% } %>
</div>

<div style="display:flex;gap:12px;margin-bottom:24px">
  <a href="/quiz/<%= student.id %>/start" class="btn btn-primary">全カテゴリ模擬試験（10問）</a>
</div>

<% if(weakQuestions.length > 0) { %>
<div class="card">
  <div class="card-header">苦手問題（直近30日）</div>
  <div class="card-body">
    <% for(const q of weakQuestions) { %>
    <div style="padding:10px 0;border-bottom:1px solid #f0f2f5">
      <span class="badge badge-orange" style="margin-right:8px"><%= q.category %></span>
      <span style="font-size:13px"><%= q.question %></span>
      <span class="text-muted" style="font-size:11px;margin-left:8px"><%= q.wrong_count %>回間違い</span>
    </div>
    <% } %>
  </div>
</div>
<% } %>

<%- include('../partials/layout-end') %>
