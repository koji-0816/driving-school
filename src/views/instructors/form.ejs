<%- include('../partials/layout-start', { title: instructor ? instructor.name + ' の編集' : '教官登録', current: 'instructors' }) %>

<a href="<%= instructor ? '/instructors/' + instructor.id : '/instructors' %>" class="text-muted" style="font-size:13px">← 戻る</a>

<div class="card mt-4" style="max-width:640px">
  <div class="card-header"><%= instructor ? '教官情報の編集' : '新規教官登録' %></div>
  <div class="card-body">

    <% if(error) { %>
    <div style="background:#fee2e2;border:1px solid #fca5a5;color:#b91c1c;padding:12px 16px;border-radius:8px;margin-bottom:16px">
      ⚠️ <%= error %>
    </div>
    <% } %>

    <form method="post" action="<%= instructor ? '/instructors/' + instructor.id + '/edit' : '/instructors' %>">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
        <div>
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">氏名 <span style="color:#dc2626">*</span></label>
          <input type="text" name="name" value="<%= instructor ? instructor.name : '' %>" required
                 style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
        </div>
        <div>
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">フリガナ <span style="color:#dc2626">*</span></label>
          <input type="text" name="kana" value="<%= instructor ? instructor.kana : '' %>" required
                 style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
        </div>
        <div style="grid-column:1/-1">
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">保有資格（車種別・カンマ区切り）</label>
          <input type="text" name="qualifications" value="<%= instructor ? instructor.qualifications : '普通車' %>"
                 placeholder="普通車,二輪,大型"
                 style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
        </div>
        <div>
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">検定員</label>
          <label style="display:flex;align-items:center;gap:8px;font-size:14px;padding:8px 0">
            <input type="checkbox" name="is_examiner" value="1" <%= instructor && instructor.is_examiner ? 'checked' : '' %>>
            検定員資格あり
          </label>
        </div>
        <div>
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">ステータス</label>
          <select name="status" style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
            <% ['在籍','休職','退職'].forEach(s => { %>
              <option value="<%= s %>" <%= instructor && instructor.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
        <div style="grid-column:1/-1">
          <label style="display:block;font-size:12px;color:#555;margin-bottom:4px">検定可能資格（カンマ区切り）</label>
          <input type="text" name="examiner_qualifications" value="<%= instructor ? instructor.examiner_qualifications || '' : '' %>"
                 placeholder="普通車,二輪"
                 style="width:100%;padding:8px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
        </div>
      </div>

      <div style="display:flex;gap:10px;margin-top:8px">
        <button type="submit" class="btn btn-primary"><%= instructor ? '更新する' : '登録する' %></button>
        <a href="<%= instructor ? '/instructors/' + instructor.id : '/instructors' %>" class="btn btn-secondary">キャンセル</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
