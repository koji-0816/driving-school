<%- include('../partials/layout-start', { title: '教習コース', current: 'courses' }) %>

<div style="background:#fffbeb;border:1px solid #fde68a;color:#854d0e;padding:10px 16px;border-radius:8px;margin:16px 0;font-size:13px">
  ⚠ 現在は閲覧のみです。コース内容・免除は暫定（要法令・現場確認）。登録・編集は現地確認後に対応します。
</div>

<div class="card">
  <div class="card-header">教習コース一覧（現行版）</div>
  <div class="card-body">
    <table>
      <tr><th>コース名</th><th>取得免許</th><th>所持条件</th><th>適用開始</th><th>必要教習数</th><th></th></tr>
      <% if(courses.length === 0) { %>
        <tr><td colspan="6" class="text-muted">コースが登録されていません</td></tr>
      <% } %>
      <% for(const c of courses) { %>
      <tr>
        <td><a href="/courses/<%= c.id %>"><%= c.course_name %></a></td>
        <td><span class="badge badge-blue"><%= c.target_license_name %></span></td>
        <td class="text-muted" style="font-size:12px"><%= c.course_family %></td>
        <td><%= c.valid_from %></td>
        <td><%= c.lesson_count %> 項目</td>
        <td><a href="/courses/<%= c.id %>" class="btn btn-secondary" style="font-size:12px;padding:4px 10px">明細</a></td>
      </tr>
      <% } %>
    </table>
  </div>
</div>

<%- include('../partials/layout-end') %>
