<%- include('../partials/layout-start', { title: course.course_name, current: 'courses' }) %>

<a href="/courses" class="text-muted" style="font-size:13px">← 教習コース一覧</a>

<div class="card mt-4 mb-4">
  <div class="card-header">コース情報</div>
  <div class="card-body">
    <table>
      <tr><th style="width:140px">コース名</th><td><strong><%= course.course_name %></strong></td></tr>
      <tr><th>取得免許</th><td><span class="badge badge-blue"><%= course.target_license_name %></span></td></tr>
      <tr><th>論理コース</th><td class="text-muted"><%= course.course_family %>（v<%= course.version %>）</td></tr>
      <tr><th>適用開始日</th><td><%= course.valid_from %></td></tr>
    </table>
  </div>
</div>

<div style="background:#fffbeb;border:1px solid #fde68a;color:#854d0e;padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px">
  ⚠ この教習セット・免除（明細に含まれない科目）は暫定です（要法令・現場確認）。<br>
  免除は「明細に入れない」で表現されます。所持なしコースに在って本コースに無い科目＝免除扱いです。
</div>

<div class="card">
  <div class="card-header">必要教習一覧（<%= lessons.length %> 項目）</div>
  <div class="card-body" style="padding:12px 20px">
    <%
      const groups = [
        { stage: 1, type: '学科', label: '第一段階 — 学科' },
        { stage: 1, type: '技能', label: '第一段階 — 技能' },
        { stage: 2, type: '学科', label: '第二段階 — 学科' },
        { stage: 2, type: '技能', label: '第二段階 — 技能' },
      ];
    %>
    <% for(const g of groups) {
      const items = lessons.filter(l => l.stage === g.stage && l.lesson_type === g.type);
      if(items.length === 0) continue;
    %>
    <div style="margin-bottom:18px">
      <div style="font-size:12px;font-weight:700;color:#6b7280;letter-spacing:0.05em;margin-bottom:8px"><%= g.label %>（<%= items.length %>）</div>
      <table style="width:100%;border-collapse:collapse">
        <% for(const l of items) { %>
        <tr style="border-bottom:1px solid #f3f4f6">
          <td style="padding:6px 0;width:64px"><span class="badge <%= l.lesson_type === '技能' ? 'badge-green' : 'badge-blue' %>"><%= l.lesson_type %></span></td>
          <td style="padding:6px 4px;font-size:12px;color:#9ca3af;white-space:nowrap"><%= l.code %></td>
          <td style="padding:6px 8px;font-size:13px"><%= l.name %></td>
          <td style="padding:6px 0;width:80px;text-align:right">
            <% if(l.is_mikiwame) { %><span class="badge badge-orange">みきわめ</span><% } %>
          </td>
        </tr>
        <% } %>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/layout-end') %>
