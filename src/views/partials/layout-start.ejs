<%
  const _uc  = locals.unreadCount     || 0;
  const _role= locals.currentRole     || 'admin';
  const _uid = locals.currentUserId   || 0;
  const _uname=locals.currentUserName || '';
%>
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — 教習所管理システム</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <div class="sidebar">
    <div class="sidebar-title">
      教習所管理システム
      <small>仮説モデル v0.1</small>
    </div>
    <nav>

      <% if(_role === 'admin') { %>
      <!-- 管理者 -->
      <div class="nav-group role-admin open">
        <div class="nav-group-header" onclick="toggleNav(this)">
          <span class="nav-role-icon">管</span>管理者メニュー
          <span class="nav-toggle">▶</span>
        </div>
        <div class="nav-group-body">
          <a href="/"              class="<%= current==='dashboard'     ?'active':'' %>">ダッシュボード</a>
          <a href="/students"      class="<%= current==='students'      ?'active':'' %>">生徒管理</a>
          <a href="/instructors"   class="<%= current==='instructors'   ?'active':'' %>">教官管理</a>
          <a href="/facilities"    class="<%= current==='facilities'    ?'active':'' %>">設備管理</a>
          <a href="/accommodation" class="<%= current==='accommodation' ?'active':'' %>">宿泊管理</a>
          <a href="/exams"         class="<%= current==='exams'         ?'active':'' %>">検定管理</a>
          <a href="/schedule"      class="<%= current==='schedule'      ?'active':'' %>">配車スケジュール</a>
          <a href="/reservations/admin" class="<%= current==='reservations'?'active':'' %>">予約枠管理</a>
          <a href="/feedback/admin" class="<%= current==='feedback'     ?'active':'' %>">フィードバック管理</a>
          <a href="/booking-routes" class="<%= current==='booking-routes'?'active':'' %>">予約経路マスター</a>
          <a href="/courses" class="<%= current==='courses'?'active':'' %>">教習コース</a>
        </div>
      </div>

      <% } else if(_role === 'staff') { %>
      <!-- 職員 -->
      <div class="nav-group role-staff open">
        <div class="nav-group-header" onclick="toggleNav(this)">
          <span class="nav-role-icon">職</span>職員メニュー
          <span class="nav-toggle">▶</span>
        </div>
        <div class="nav-group-body">
          <a href="/schedule"           class="<%= current==='schedule'     ?'active':'' %>">配車スケジュール</a>
          <a href="/reservations/admin" class="<%= current==='reservations' ?'active':'' %>">予約枠管理</a>
          <a href="/students"           class="<%= current==='students'     ?'active':'' %>">生徒一覧</a>
        </div>
      </div>

      <% } else if(_role === 'instructor') { %>
      <!-- 教員 -->
      <div class="nav-group role-instructor open">
        <div class="nav-group-header" onclick="toggleNav(this)">
          <span class="nav-role-icon">教</span><%= _uname %>
          <span class="nav-toggle">▶</span>
        </div>
        <div class="nav-group-body">
          <a href="/instructors/<%= _uid %>"            class="<%= current==='instructors'?'active':'' %>">自分のプロフィール</a>
          <a href="/schedule?instructor_id=<%= _uid %>" class="<%= current==='schedule'   ?'active':'' %>">自分のスケジュール</a>
          <a href="/exams"                              class="<%= current==='exams'      ?'active':'' %>">検定（試験官）</a>
        </div>
      </div>

      <% } else if(_role === 'student') { %>
      <!-- 生徒 -->
      <div class="nav-group role-student open">
        <div class="nav-group-header" onclick="toggleNav(this)">
          <span class="nav-role-icon">生</span><%= _uname %>
          <span class="nav-toggle">▶</span>
        </div>
        <div class="nav-group-body">
          <a href="/students/mypage"               class="<%= current==='mypage'       ?'active':'' %>">マイページ</a>
          <a href="/students/<%= _uid %>"           class="<%= current==='students'     ?'active':'' %>">教習進捗</a>
          <a href="/reservations/book/<%= _uid %>"  class="<%= current==='reservations' ?'active':'' %>">空き枠・予約</a>
          <a href="/reservations/my/<%= _uid %>">自分の予約一覧</a>
          <a href="/quiz/<%= _uid %>"               class="<%= current==='quiz'         ?'active':'' %>">学科試験対策</a>
          <a href="/feedback/new/<%= _uid %>"       class="<%= current==='feedback'     ?'active':'' %>">フィードバック</a>
          <a href="/notifications/<%= _uid %>"      class="<%= current==='notifications'?'active':'' %>">
            お知らせ<% if(_uc > 0) { %> <span class="badge badge-red" style="font-size:11px"><%= _uc %></span><% } %>
          </a>
          <a href="/graduation"                    class="<%= current==='graduation'   ?'active':'' %>">卒業後のご案内</a>
        </div>
      </div>
      <% } else if(_role === 'parent') { %>
      <!-- 保護者 -->
      <div class="nav-group open">
        <div class="nav-group-header" onclick="toggleNav(this)">
          <span class="nav-role-icon">保</span>保護者メニュー
          <span class="nav-toggle">▶</span>
        </div>
        <div class="nav-group-body">
          <a href="/parents/<%= _uid %>">教習状況確認</a>
        </div>
      </div>
      <% } %>

      <!-- 共通フッター -->
      <a href="/select" style="display:block;padding:10px 16px;font-size:11px;color:#557799;border-top:1px solid #253548;margin-top:8px">
        ⇄ ユーザー切り替え
      </a>
      <a href="/help" class="<%= current==='help'?'active':'' %>" style="font-size:12px;color:#557799">
        操作ガイド
      </a>

    </nav>
  </div>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="hamburger" onclick="toggleSidebar()" aria-label="メニュー">
          <span></span><span></span><span></span>
        </button>
        <h1><%= title %></h1>
      </div>
      <div style="display:flex;align-items:center;gap:16px">
        <span style="font-size:12px;color:#888">
          <%= _uname %>（<%= _role === 'admin' ? '管理者' : _role === 'staff' ? '職員' : _role === 'instructor' ? '教員' : _role === 'parent' ? '保護者' : '生徒' %>）
        </span>
        <span class="date"><%= new Date().toLocaleDateString('ja-JP', { year:'numeric', month:'long', day:'numeric', weekday:'short' }) %></span>
      </div>
    </div>
    <div class="content">

<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<script>
function toggleNav(header) {
  header.closest('.nav-group').classList.toggle('open');
}
function toggleSidebar() {
  document.querySelector('.sidebar').classList.toggle('open');
  document.querySelector('.sidebar-overlay').classList.toggle('open');
}
</script>
